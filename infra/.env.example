# Copy to infra/.env for local development. Never commit the real .env file.
# MySQL: one database per service (product_service, crm_service,
# inventory_service, order_service), created by infra/mysql-init on first
# boot — no MYSQL_DATABASE var needed.
MYSQL_ROOT_PASSWORD=changeme
MONGO_ROOT_USERNAME=coresuite
MONGO_ROOT_PASSWORD=changeme
REDIS_PASSWORD=changeme
